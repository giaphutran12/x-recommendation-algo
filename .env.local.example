# ─── Next.js App (Supabase client) ───
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Gemini (embeddings) ───
GOOGLE_AI_API_KEY=your-gemini-api-key

# ─── Two-Tower Training (Python — direct Postgres connection) ───
# Used by: python3 training/two_tower.py
# Format:  postgresql://postgres.[project-ref]:[password]@[host]:6543/postgres
# Local Supabase: postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
